# Copy to .env (gitignored) and fill in only what you need to override.
# Used by scripts/write-environment-ios.mjs to generate the gitignored
# src/environments/environment.ios.local.ts / environment.ios.prod.ts files
# consumed by the `ios-local` / `ios-prod` angular.json build configurations.

# Local dev (npm run build:ios:local / sync:ios:local):
# The Mac's LAN IP is auto-detected (os.networkInterfaces(), preferring en0)
# so most setups need neither of these. Set IOS_LAN_HOST if auto-detection
# picks the wrong interface (e.g. a VPN is also active); set
# IOS_BACKEND_ORIGIN_LOCAL instead if you need a full origin override
# (different port, https, etc).
# IOS_LAN_HOST=192.168.0.21
# IOS_BACKEND_ORIGIN_LOCAL=http://192.168.0.21:3000

# Prod (npm run build:ios:prod / sync:ios:prod):
# Required — no default is set here on purpose (this repo has no fixed prod
# host to fall back to). Set this to your deployed backend's origin — see
# docs/nas-deployment.md for the self-hosted NAS/Tailscale setup this repo
# actually uses. Note: changing the *GitHub secret* value alone does not
# trigger a rebuild (see docs/nas-deployment.md step 6) — this local .env
# value only affects builds run from your own machine.
# IOS_BACKEND_ORIGIN_PROD=https://your-production-host
# BACKEND_ORIGIN=https://optional-generic-fallback-origin

# Push notifications (npm run prebuild:ios, via scripts/bootstrap-ios-firebase-plist.mjs):
# GoogleService-Info.plist is machine-local, not committed. Defaults to
# ~/.config/go-gather/ios/GoogleService-Info.plist; override the source path
# with this if you keep it somewhere else.
# IOS_FIREBASE_PLIST_PATH=/path/to/GoogleService-Info.plist

# Server-side (docker-compose.yml / NAS deployment): set FIREBASE_SERVICE_ACCOUNT_JSON
# to the Firebase project's service-account JSON (Firebase Console -> Project
# Settings -> Service Accounts -> Generate new private key), as a single-line
# JSON string.
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# Specifies intentionally untracked files to ignore when using Git
# http://git-scm.com/docs/gitignore

*~
*.sw[mnpcod]
.tmp
*.tmp
*.tmp.*
UserInterfaceState.xcuserstate
$RECYCLE.BIN/

*.log
log.txt


/.sourcemaps
/.versions
/coverage

# Ionic
/.ionic
/www
/platforms
/plugins

# OTA live-update build artifacts (scripts/build-ios-live-update-artifacts.mjs)
/ota

# iOS environment layering (scripts/write-environment-ios.mjs generates these
# just before an ios-local/ios-prod build; see .env.example)
/src/environments/environment.ios.local.ts
/src/environments/environment.ios.prod.ts
/.env

# Compiled output
/dist
/tmp
/out-tsc
/bazel-out

# Node (unanchored so this also matches npm workspace packages'
# node_modules, e.g. shared/node_modules, server/node_modules)
node_modules/
npm-debug.log
yarn-error.log

# Server sync data (regenerate via `npm run sync` in server/)
server/data/*.db
server/data/*.db-journal
server/data/*.db-wal
server/data/*.db-shm
server/data/images/
!server/data/.gitkeep

# docker-compose.yml's default bind-mount target (NAS_DATA_ROOT default) —
# local-only when running the compose stack from a repo checkout
/nas-data

# docker-compose.yml's default bind-mount target (SECRETS_HOST_DIR default)
# for /run/secrets — e.g. firebase_service_account_json, never committed
/nas-secrets

# OTA live-update artifacts served by the server (baked in at Docker build
# time by build-ios-live-update-artifacts.mjs; see /ota above for the
# repo-root default output location that gets copied in from there)
server/ota/*
!server/ota/.gitkeep

# Server-side user-data backups (backup.ts) — real catch-progress/settings
# data, written on every startup and never meant to be committed
server/backups/*
!server/backups/.gitkeep

# IDEs and editors
.idea/
.project
.classpath
.c9/
*.launch
.settings/
*.sublime-project
*.sublime-workspace

# Visual Studio Code
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
.history/*


# Miscellaneous
/.angular
/.angular/cache
.sass-cache/
/.nx
/.nx/cache
/connect.lock
/coverage
/libpeerconnection.log
testem.log
/typings

# System files
.DS_Store
Thumbs.db
.claude/settings.json
